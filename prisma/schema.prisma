generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

// Application users with authentication credentials and access role.
model User {
  id       String @id @default(uuid())
  name     String
  email    String
  password String
  role     Role   @default(USER)

  @@map("users")
}

// Customers who make reservations and hold contact details.
model Client {
  id        String @id @default(uuid())
  name      String
  last_name String
  doc       String
  email     String
  address   String
  country   String
  state     String
  phone     String

  reservations Reservation[]

  @@map("clients")
}

// Reservable assets or services available for booking.
model Resource {
  id          String @id @default(uuid())
  name        String
  description String

  reservations Reservation[]

  @@map("resources")
}

/**
 * Reservation data with price and status tracking.
 * - `confirmed`: Whether the reservation has been confirmed.
 * - `active`: Whether these dates are available for reservation.
 * - The reservation total days includes both the start date and end date.
*/
model Reservation {
  id           String   @id @default(uuid())
  start_date   DateTime
  end_date     DateTime
  id_resource  String
  id_client    String?
  observation  String?
  price        Float

  confirmed Boolean @default(false)
  active    Boolean @default(true)

  payments Payment[]

  resource Resource @relation(fields: [id_resource], references: [id])
  client   Client?  @relation(fields: [id_client], references: [id])

  @@map("reservations")
}

// Payment records associated with reservations.
model Payment {
  id             String   @id @default(uuid())
  date           DateTime
  id_reservation String
  amount         Float
  observations   String?

  reservation Reservation @relation(fields: [id_reservation], references: [id])

  @@index([id_reservation])
  @@map("payments")
}
