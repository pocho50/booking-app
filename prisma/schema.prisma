generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String
  password String
  role     Role   @default(USER)

  @@map("users")
}

model Client {
  id        String @id @default(uuid())
  name      String
  last_name String
  doc       String
  email     String
  address   String
  country   String
  state     String
  phone     String

  reservations Reservation[]

  @@map("clients")
}

model Resource {
  id          String @id @default(uuid())
  name        String
  description String

  reservations Reservation[]

  @@map("resources")
}

model Reservation {
  id           String   @id @default(uuid())
  start_date   DateTime
  end_date     DateTime
  id_resource  String
  id_client    String?
  observation  String?
  price        Float

  confirmed Boolean @default(false)
  active    Boolean @default(true)

  billings Billing[]

  resource Resource @relation(fields: [id_resource], references: [id])
  client   Client?  @relation(fields: [id_client], references: [id])

  @@map("reservations")
}

model Billing {
  id             String   @id @default(uuid())
  date           DateTime
  id_reservation String
  amount         Float
  observations   String?

  reservation Reservation @relation(fields: [id_reservation], references: [id])

  @@index([id_reservation])
  @@map("billings")
}
