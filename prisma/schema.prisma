generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Client {
  id        String @id @default(uuid())
  name      String
  last_name String
  doc       String
  email     String
  address   String
  country   String
  state     String
  phone     String

  @@map("clients")
}
