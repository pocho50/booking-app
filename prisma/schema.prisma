generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Client {
  id        String @id @default(uuid())
  name      String
  last_name String
  doc       String
  email     String
  address   String
  country   String
  state     String
  phone     String

  reservations Reservation[]

  @@map("clients")
}

model Resource {
  id          String @id @default(uuid())
  name        String
  description String

  reservations Reservation[]

  @@map("resources")
}

model Reservation {
  id           String   @id @default(uuid())
  start_date   DateTime
  end_date     DateTime
  id_resource  String
  id_client    String?
  observation  String?
  price        Float

  confirmed Boolean @default(false)
  active    Boolean @default(true)

  resource Resource @relation(fields: [id_resource], references: [id])
  client   Client?  @relation(fields: [id_client], references: [id])

  @@map("reservations")
}
